# ─────────────────────────────────────────────
# Backend 환경변수 예시
# Railway-only 기준: 저장소 루트(.env) 또는 backend/.env 에 작성
# 실제 값은 절대 커밋하지 않는다.
# ─────────────────────────────────────────────

# ── 데이터베이스 ─────────────────────────────
# Railway TCP Proxy 예시:
# postgresql://postgres:<password>@<tcp-proxy-host>:<port>/railway
# 필요 시 sslmode 파라미터를 추가한다. (?sslmode=disable)
DATABASE_URL=postgresql://postgres:password@centerbeam.proxy.rlwy.net:33022/railway

# ── AI API (google-genai SDK 사용) ──────────
# Google AI Studio에서 API 키 발급: https://aistudio.google.com/apikey
# 하나의 키로 Gemini Flash, Imagen 3, Veo 모두 사용
GEMINI_API_KEY=your_gemini_api_key_here

# 모델 이름 (기본값 사용 권장)
GEMINI_FLASH_MODEL=gemini-2.0-flash
IMAGEN_MODEL=imagen-3.0-generate-002
VEO_MODEL=veo-2.0-generate-001

# ── 기능 플래그 ──────────────────────────────
# true: 실제 API 호출 없이 Mock 데이터 반환 (개발/테스트용)
# false: 실 API 호출 (배포 환경)
USE_MOCK_AI=true

# ── CORS ─────────────────────────────────────
# 쉼표로 구분하여 여러 도메인 허용 가능
# 예: https://pocketman.vercel.app,http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000

# ── AI 재시도 설정 ────────────────────────────
AI_MAX_RETRIES=3
AI_REQUEST_TIMEOUT_SEC=30
AI_RETRY_BASE_DELAY_SEC=1

# ── 생성 파일 저장 ────────────────────────────
# 생성 이미지/영상 파일 저장 경로 (기본값: backend/static/generated/)
# GENERATED_FILES_DIR=/app/static/generated
# 외부 접근 가능한 API base URL (이미지 URL 생성에 사용)
API_BASE_URL=http://localhost:8000

# ── DB 커넥션 풀 ─────────────────────────────
DB_POOL_MIN_CONN=2
DB_POOL_MAX_CONN=10

# ── 인증 ─────────────────────────────────────
JWT_SECRET_KEY=your-secret-key-here
