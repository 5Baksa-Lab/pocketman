# ─────────────────────────────────────────────
# Backend 환경변수 예시
# Railway-only 기준: 저장소 루트(.env) 또는 backend/.env 에 작성
# 실제 값은 절대 커밋하지 않는다.
# ─────────────────────────────────────────────

# ── 데이터베이스 ─────────────────────────────
# Railway TCP Proxy 예시:
# postgresql://postgres:<password>@<tcp-proxy-host>:<port>/railway
# 필요 시 sslmode 파라미터를 추가한다. (?sslmode=disable)
DATABASE_URL=postgresql://postgres:password@centerbeam.proxy.rlwy.net:33022/railway

# ── AI API ───────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
IMAGEN_API_URL=
VEO_API_URL=

# ── 기능 플래그 ──────────────────────────────
# true: 실제 API 호출 없이 Mock 데이터 반환 (개발/테스트용)
# false: 실 API 호출 (배포 환경)
USE_MOCK_AI=true

# ── CORS ─────────────────────────────────────
# 쉼표로 구분하여 여러 도메인 허용 가능
# 예: https://pocketman.vercel.app,http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000

# ── AI 재시도 설정 ────────────────────────────
AI_MAX_RETRIES=3
AI_REQUEST_TIMEOUT_SEC=30
AI_RETRY_BASE_DELAY_SEC=1

# ── DB 커넥션 풀 ─────────────────────────────
DB_POOL_MIN_CONN=2
DB_POOL_MAX_CONN=10
