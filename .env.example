# =============================================================================
# Pokéman 환경변수 (.env)
# 이 파일을 .env로 복사한 뒤 값을 채우세요. 절대 커밋하지 마세요.
# =============================================================================

# ── 데이터베이스 ─────────────────────────────────────────────────────
# 로컬 Docker: docker-compose up -d db 후 아래 값 그대로 사용
# Railway: postgresql://postgres:<password>@<host>:<port>/railway
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/pocketman

# ── CORS ─────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000

# ── AI 설정 ──────────────────────────────────────────────────────────
# true: 실 API 호출 없이 Mock 데이터 반환 (개발용)
# false: 실 API 호출 (GEMINI_API_KEY 필수)
USE_MOCK_AI=true

# Google AI API 키 (Gemini Flash / Imagen 3 / Veo 공통)
# 발급: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# 모델명 (기본값 권장)
GEMINI_FLASH_MODEL=gemini-2.0-flash
IMAGEN_MODEL=imagen-3.0-generate-002
VEO_MODEL=veo-2.0-generate-001

# AI 재시도
AI_MAX_RETRIES=2
AI_REQUEST_TIMEOUT_SEC=30
AI_RETRY_BASE_DELAY_SEC=0.8

# ── 생성 파일 저장 ───────────────────────────────────────────────────
API_BASE_URL=http://localhost:8000
# GENERATED_FILES_DIR=  # 기본값: backend/static/generated/

# ── DB 커넥션 풀 ────────────────────────────────────────────────────
DB_POOL_MIN_CONN=2
DB_POOL_MAX_CONN=10

# ── 인증 ─────────────────────────────────────────────────────────────
JWT_SECRET_KEY=dev-local-secret-change-in-production
