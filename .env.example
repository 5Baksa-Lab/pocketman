# Railway-only runtime configuration
# Copy to .env and fill secrets. Never commit .env.

# Railway PostgreSQL TCP proxy DSN example
# Note: if your Railway project requires it, append ?sslmode=disable
DATABASE_URL=postgresql://postgres:<db_password>@<tcp_proxy_host>:<tcp_proxy_port>/railway

# Comma-separated CORS origins
ALLOWED_ORIGINS=http://localhost:3000,https://your-frontend-domain.vercel.app

# AI flags/endpoints
USE_MOCK_AI=true
GEMINI_API_KEY=
IMAGEN_API_URL=
VEO_API_URL=
GEMINI_FLASH_MODEL=gemini-2.0-flash
AI_MAX_RETRIES=3
AI_REQUEST_TIMEOUT_SEC=30
AI_RETRY_BASE_DELAY_SEC=1
DB_POOL_MIN_CONN=2
DB_POOL_MAX_CONN=10
